# Copy this file to .env and fill in values before running the app.
# .env is gitignored and never committed.

# Django
DJANGO_SECRET_KEY=your_django_key               # generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DEBUG=True                          # set to False in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (matches docker-compose.yaml service)
DB_PASSWORD=your_db_password
DB_HOST=localhost                   # use 'db' when running inside Docker Compose

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0   # use redis://redis:6379/0 inside Docker Compose

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key

# CORS (dev only — not needed in production behind nginx)
CORS_ALLOWED_ORIGINS=http://localhost:3000
