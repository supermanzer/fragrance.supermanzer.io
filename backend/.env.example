# Copy this file to backend/.env and fill in values before running the app.
# backend/.env is gitignored and never committed.
#
# Root-level secrets (REDIS_PASSWORD, SEARXNG_SECRET, PUBLIC_API_BASE) live in
# the root .env file and are injected into these containers by docker-compose.

# Django
DJANGO_SECRET_KEY=your_django_key               # generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DEBUG=True                          # set to False in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_PASSWORD=your_db_password
DB_HOST=db                          # use 'localhost' when running Django outside Docker

# Redis — REDIS_PASSWORD is injected by docker-compose from root .env.
# REDIS_HOST defaults to 'redis'; override for non-Docker local dev if needed.
# REDIS_HOST=localhost
# CELERY_BROKER_URL can override the auto-constructed URL entirely if needed.

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key

# Email — sent via Postmark REST API (no SMTP ports needed)
# Create a Server API Token at: account.postmarkapp.com → Servers → your server → API Tokens
# The From address must be a verified Sender Signature in your Postmark account.
POSTMARK_SERVER_TOKEN=your_postmark_server_token
DEFAULT_FROM_EMAIL=noreply@supermanzer.io       # optional; defaults to noreply@supermanzer.io

# CORS — required; no default, startup fails if unset
CORS_ALLOWED_ORIGINS=http://localhost:3000
